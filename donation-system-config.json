{
  "name": "blood-donation-system",
  "version": "1.0.0",
  "description": "Système de gestion des dons de sang ergonomique et testable",
  "scripts": {
    "test:api": "node test-donations.js",
    "test:bash": "bash test-donations.sh",
    "seed": "node seed-data.js",
    "dev:backend": "node server.js",
    "dev:frontend": "cd ../frontend && npm run dev"
  },
  "environment": {
    "development": {
      "MONGO_URI": "mongodb://localhost:27017/blood-donation",
      "PORT": 5000,
      "NODE_ENV": "development",
      "API_URL": "http://localhost:5000"
    },
    "production": {
      "MONGO_URI": "mongodb+srv://user:password@cluster.mongodb.net/blood-donation",
      "PORT": 8080,
      "NODE_ENV": "production",
      "API_URL": "https://api.example.com"
    }
  },
  "endpoints": {
    "POST /api/donations": {
      "description": "Créer un nouveau don",
      "body": {
        "donorId": "string (ObjectId)",
        "hospitalId": "string (ObjectId)",
        "volume": "number (100-1000)",
        "healthNote": "string (Normal|Fatigue|Tension Basse|Autre)"
      },
      "response": 201,
      "example": {
        "_id": "507f1f77bcf86cd799439013",
        "donorId": "507f1f77bcf86cd799439011",
        "hospitalId": "507f1f77bcf86cd799439012",
        "volume": 450,
        "healthNote": "Normal",
        "status": "completed",
        "donationDate": "2026-04-10T07:30:00.000Z"
      }
    },
    "GET /api/donations/:donorId": {
      "description": "Récupérer l'historique des dons",
      "response": 200,
      "example": [
        {
          "_id": "507f1f77bcf86cd799439013",
          "volume": 450,
          "status": "completed",
          "donationDate": "2026-04-10T07:30:00.000Z"
        }
      ]
    }
  },
  "files": {
    "frontend": {
      "DonationForm.jsx": "Composant React principal",
      "DonationForm.css": "Styles ergonomiques (Bastien & Scapin)"
    },
    "backend": {
      "test-donations.js": "Tests automatisés Node.js",
      "test-donations.sh": "Tests automatisés Bash",
      "seed-data.js": "Insérer données de test",
      "postman-collection.json": "Collection Postman"
    },
    "docs": {
      "QUICK_START.md": "Démarrage rapide",
      "INSTALLATION_GUIDE.md": "Guide d'installation",
      "TESTING_GUIDE.md": "Guide de test",
      "DONATION_GUIDE.md": "Guide complet",
      "README_DONATION_SYSTEM.md": "Vue d'ensemble"
    }
  },
  "features": [
    "Formulaire React ergonomique",
    "Validation frontend + backend",
    "Gestion d'erreurs détaillée",
    "Messages de feedback clairs",
    "Responsive design",
    "Accessibilité WCAG 2.1",
    "Icônes animées (Lucide React)",
    "Tests automatisés",
    "Données de seed",
    "Documentation complète",
    "Critères Bastien & Scapin appliqués"
  ],
  "dependencies": {
    "frontend": [
      "react@19.2.4",
      "react-dom@19.2.4",
      "react-router-dom@7.14.0",
      "axios@1.15.0",
      "lucide-react@1.8.0"
    ],
    "backend": [
      "express",
      "mongoose",
      "cors"
    ]
  },
  "testing": {
    "scenarios": 7,
    "coverage": [
      "Donation valide",
      "Volume minimum (100 ml)",
      "Volume maximum (1000 ml)",
      "Donneur invalide",
      "Hôpital invalide",
      "Champs manquants",
      "Récupération historique"
    ]
  },
  "ergonomic_criteria": [
    "Guidage",
    "Charge de travail",
    "Contrôle explicite",
    "Adaptabilité",
    "Gestion des erreurs",
    "Homogénéité/Conformité",
    "Signifiance du codage",
    "Compatibilité"
  ],
  "quick_commands": {
    "install_seed": "cd backend && node seed-data.js",
    "test_api": "cd backend && node test-donations.js",
    "start_backend": "cd backend && node server.js",
    "start_frontend": "cd frontend && npm run dev",
    "view_form": "Open http://localhost:5173/donate"
  }
}
